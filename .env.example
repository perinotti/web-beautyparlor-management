# Este é um ficheiro de exemplo. Copie este ficheiro para .env e preencha com as suas credenciais reais.
# NUNCA envie o seu ficheiro .env para o GitHub.

# URL de conexão: postgresql://usuario:senha@localhost:port/nome_do_banco
DATABASE_URL=postgresql://seu_usuario:sua_senha@localhost:5432/beauty_parlor
SECRET_KEY=sua_chave_secreta_aqui
SESSION_MAX_AGE_SECONDS=36000
SESSION_HTTPS_ONLY=false
